""""""""""""""""""""
" 各種オプション設定（vim/ideavim共通の設定＝ideavimで設定できる項目）
" https://github.com/JetBrains/ideavim/wiki/set-commands
""""""""""""""""""""
" 入力中のコマンド表示
set showcmd
" モードの表示
set showmode
" 検索設定
set hlsearch
set incsearch
" カーソルを行頭・行末で止まらないようにする
set whichwrap=b,s,h,l,<,>,[,]

" クリップボードをOSと共通利用する
set clipboard=unnamedplus
